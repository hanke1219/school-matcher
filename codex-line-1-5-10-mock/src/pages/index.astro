import schools from "../data/schools.json";
import weights from "../data/weights.json";
import kaichiReport from "../data/reports/kaichi-nihonbashi.json";

const reports = {
  "kaichi-nihonbashi": kaichiReport,
};
---

<BaseLayout>
  <DecisionApp client:load schools={schools} weights={weights} reports={reports} />
</BaseLayout>
